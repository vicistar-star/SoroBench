{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@sorobench/cli": ["./packages/cli/src"],
      "@sorobench/runner": ["./packages/runner/src"],
      "@sorobench/flamegraph": ["./packages/flamegraph/src"],
      "@sorobench/storage": ["./packages/storage/src"],
      "@sorobench/dashboard": ["./packages/dashboard/src"]
    }
  },
  "exclude": ["node_modules", "dist", "target"]
}
